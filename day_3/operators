# Prompt user to enter number of years
years = int(input("Enter number of years you have lived: "))

# Constants
seconds_in_one_year = 365 * 24 * 60 * 60

# Calculate seconds lived
seconds_lived = years * seconds_in_one_year

# Calculate total seconds in 100 years
max_years = 100
total_seconds_100_years = max_years * seconds_in_one_year

# Display results
print("You have lived for", seconds_lived, "seconds.")
print("If you live up to 100 years, you can live for", total_seconds_100_years, "seconds.")


